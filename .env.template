# Azure Environment Variables Template
# Copy this file to .env and fill in the required values for local development

# === LOCAL DEVELOPMENT SETTINGS ===

# Local Database Configuration (choose one option below)

# Option 1: SQL Server LocalDB (Windows only)
# ASPNETCORE_ConnectionStrings__DefaultConnection=Server=(localdb)\MSSQLLocalDB;Database=BizCrmDb;Trusted_Connection=true;MultipleActiveResultSets=true;TrustServerCertificate=true

# Option 2: SQL Server with SQL Authentication (localhost)
ASPNETCORE_ConnectionStrings__DefaultConnection=Server=localhost;Database=BizCrmDb;User Id=sa;Password=your-password-here;MultipleActiveResultSets=true;TrustServerCertificate=true

# Application Environment
ASPNETCORE_ENVIRONMENT=Development
DOTNET_ENVIRONMENT=Development

# Local Server URLs
ASPNETCORE_URLS=https://localhost:7001;http://localhost:5001
ASPNETCORE_HTTP_PORT=5001
ASPNETCORE_HTTPS_PORT=7001

# CORS Configuration (allows frontend to connect to backend)
CORS_ORIGINS=http://localhost:5173,https://localhost:5173,http://localhost:3000

# Frontend Configuration
VITE_API_BASE_URL=https://localhost:7001
VITE_API_BASE_URL_HTTP=http://localhost:5001
VITE_APP_NAME=BizCrm
VITE_APP_VERSION=1.0.0
VITE_ENVIRONMENT=development

# === AZURE DEPLOYMENT SETTINGS (for production) ===

# Azure Configuration
AZURE_SUBSCRIPTION_ID=your-subscription-id-here
AZURE_RESOURCE_GROUP=rg-bizcrm-dev
AZURE_LOCATION=centralus
AZURE_ENV_NAME=bizcrm-dev

# Production Database Configuration
DATABASE_SERVER_NAME=sql-bizcrm-dev
DATABASE_NAME=BizCrm
DATABASE_ADMIN_LOGIN=bizcrm_admin
DATABASE_ADMIN_PASSWORD=your-strong-password-here

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production-minimum-32-characters
JWT_ISSUER=BizCrmAPI
JWT_AUDIENCE=BizCrmClient
JWT_EXPIRY_MINUTES=60

# SignalR Configuration
SIGNALR_HUB_URL=https://localhost:7001/hubs/notifications

# Hangfire Configuration
HANGFIRE_DASHBOARD_PATH=/hangfire
HANGFIRE_DASHBOARD_ENABLED=true
HANGFIRE_USERNAME=admin
HANGFIRE_PASSWORD=your-hangfire-password-here

# Logging Configuration
LOGGING_LEVEL_DEFAULT=Information
LOGGING_LEVEL_MICROSOFT=Warning
LOGGING_LEVEL_SYSTEM=Warning

# Security Configuration
ENABLE_HTTPS_REDIRECTION=true
ENABLE_SECURITY_HEADERS=true
ENABLE_SWAGGER=true
ENABLE_DEVELOPER_EXCEPTION_PAGE=true

# Email Configuration (optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@bizcrm.com
SMTP_FROM_NAME=BizCRM System

# File Upload Configuration
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_EXTENSIONS=.pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png,.gif

# Legacy local connection string (deprecated - use ASPNETCORE_ConnectionStrings__DefaultConnection instead)
CONNECTION_STRING=Server=(localdb)\mssqllocaldb;Database=BizCrm_Dev;Trusted_Connection=true;MultipleActiveResultSets=true

# Azure Resources (will be populated by azd)
AZURE_CONTAINER_REGISTRY_NAME=
AZURE_CONTAINER_APPS_ENVIRONMENT_NAME=
AZURE_KEY_VAULT_NAME=
AZURE_APPLICATION_INSIGHTS_NAME=
AZURE_SQL_SERVER_NAME=
AZURE_STATIC_WEB_APP_NAME=
AZURE_BACKEND_CONTAINER_APP_NAME=